# Artifactory npm registry - replace with your organisation's registry URL
# PLACEHOLDER: Set PFG_ARTIFACTORY_NPM_AUTH secret in GitHub repository settings
# registry=https://<YOUR_ARTIFACTORY_HOST>/artifactory/api/npm/<REPO_KEY>/
# //:<YOUR_ARTIFACTORY_HOST>/artifactory/api/npm/<REPO_KEY>/:_auth=${PFG_ARTIFACTORY_NPM_AUTH}

# Default registry (used if no private registry is configured)
registry=https://registry.npmjs.org/

save-exact=true
