{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "commonjs",
    "lib":             ["es2020"],
    "declaration":     true,
    "strict":          true,
    "noImplicitAny":   true,
    "strictNullChecks":true,
    "outDir":          "./dist",
    "rootDir":         "./",
    "esModuleInterop": true,
    "resolveJsonModule":true
  },
  "exclude": ["node_modules", "cdk.out", "dist"]
}
